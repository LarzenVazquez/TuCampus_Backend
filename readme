Creacion de base de datos
CREATE DATABASE IF NOT EXISTS tucampus_sql;
USE tucampus_sql;

-- 1. Tabla Principal: Usuarios
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(150) NOT NULL,
    email VARCHAR(255) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL,
    matricula VARCHAR(50) UNIQUE,
    rol ENUM('admin', 'staff', 'comprador', 'vendedor') DEFAULT 'comprador',
    es_vendedor_verificado TINYINT(1) DEFAULT 0,
    foto_identificacion_url VARCHAR(255),
    codigo_recuperacion VARCHAR(10),
    token_auth_2fa VARCHAR(100),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    -- ГЌndices para que el Login y las bГєsquedas vuelen
    INDEX (email),
    INDEX (rol)
);

-- 2. Tabla de Sesiones
CREATE TABLE sessions (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    token VARCHAR(500) NOT NULL,
    expira_en DATETIME NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 3. Tabla de Logs
CREATE TABLE activity_logs (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    accion VARCHAR(255),
    descripcion TEXT,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL
);

